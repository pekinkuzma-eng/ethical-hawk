from scapy.all import sniff
from scapy.layers.inet import IP, TCP
from scapy.packet import Raw

from core.detector import Detector
from config import INTERFACE


detector = Detector()


class Sniffer:

   def process_packet(self, packet):
	

        try:

            if (
                packet.haslayer(IP)
                and packet.haslayer(TCP)
            ):

                source_ip = packet[IP].src

                # multicast filter
                if (
                    source_ip.startswith("239.")
                    or source_ip.startswith("224.")
                ):
                    return

                payload = ""

                if packet.haslayer(Raw):

                    payload = packet[Raw].load.decode(
                        errors="ignore"
                    )

                    # ignore SSDP
                    if "NOTIFY" in payload:
                        return

                    # показываем только HTTP-like payload
                    if (
                        "GET" in payload
                        or "POST" in payload
                        or "HTTP" in payload
                    ):

                        print(
                            f"[HTTP PACKET] "
                            f"{source_ip} -> "
                            f"{payload[:200]}"
                        )

                    # SQLi
                    if detector.detect_sql_injection(payload):

                        detector.process_attack(
                            source_ip,
                            payload,
                            "SQL Injection"
                        )

                    # XSS
                    elif detector.detect_xss(payload):

                        detector.process_attack(
                            source_ip,
                            payload,
                            "XSS Attack"
                        )

                    # brute-force
                    elif detector.detect_bruteforce(
                        source_ip
                    ):

                        detector.process_attack(
                            source_ip,
                            payload,
                            "Brute Force"
                        )

        except Exception as error:

            print(
                f"[SNIFFER ERROR] {error}"
            )

    def start(self):

        print(
            "[INFO] Traffic monitoring started..."
        )

        sniff(
            iface=INTERFACE,
            filter="tcp port 80",
            prn=self.process_packet,
            store=False
        )
